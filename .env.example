# DailyFill — Production (Vercel + Supabase)

# Supabase — required for production
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role — for Admin API (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin panel password (optional, defaults to dailyfill2026)
ADMIN_PASSWORD=dailyfill2026
