# DailyFill — Production (Vercel + Supabase)

# Supabase — required for production
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role — for Admin API (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin panel password (optional, defaults to dailyfill2026)
ADMIN_PASSWORD=dailyfill2026

# Vercel Deploy Hook — for "Deploy to Vercel" button in admin dashboard
# Create at: Vercel Project → Settings → Git → Deploy Hooks
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...
